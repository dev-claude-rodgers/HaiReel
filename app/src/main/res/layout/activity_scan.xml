<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        android:elevation="4dp" />

    <!-- 件数カウンター -->
    <TextView
        android:id="@+id/tvCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 件追加済み"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="?attr/colorPrimary" />

    <!-- 認識結果エリア -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="撮影をタップして伝票を読み込む"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:padding="10dp"
        android:textSize="15sp"
        android:inputType="textPersonName"
        android:hint="氏名または店名（省略可）"
        android:background="@android:color/transparent"
        android:importantForAutofill="no" />

    <EditText
        android:id="@+id/etAddress"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:padding="10dp"
        android:textSize="16sp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:hint="住所を確認・編集"
        android:background="@android:color/transparent"
        android:importantForAutofill="no" />

    <!-- ボタンエリア -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📷 撮影"
            android:contentDescription="伝票を撮影する"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="追加"
                android:contentDescription="認識した住所を追加"
                android:enabled="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="スキップ"
                android:contentDescription="この伝票をスキップ"
                android:enabled="false" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="取り込む"
            android:contentDescription="スキャンを完了してルートに取り込む"
            android:enabled="false" />

    </LinearLayout>

</LinearLayout>
