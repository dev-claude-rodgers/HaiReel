<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- 月ナビゲーションヘッダー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/colorSurfaceContainerHigh"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevMonth"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="‹"
            android:contentDescription="前の月"
            android:textSize="22sp"
            android:textColor="?attr/colorOnSurface"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="24dp" />

        <TextView
            android:id="@+id/tvMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextMonth"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="›"
            android:contentDescription="次の月"
            android:textSize="22sp"
            android:textColor="?attr/colorOnSurface"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTenkoMenu"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="≡"
            android:contentDescription="点呼メニュー"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="28dp" />

    </LinearLayout>

    <!-- 記録あり時の長押しヒント -->
    <TextView
        android:id="@+id/tvLongPressHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="便を長押しすると記録を削除できます"
        android:textSize="11sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="?attr/colorSurfaceContainer"
        android:visibility="gone" />

    <!-- 未記録ヒントバナー（当月に記録が1件もない時のみ表示） -->
    <LinearLayout
        android:id="@+id/emptyMonthBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="20dp"
        android:background="@color/colorTenkoDoneBg"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 今月の点呼記録はまだありません"
            android:textSize="14sp"
            android:textColor="@color/colorTenkoDoneFg"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="日付をタップして乗務前・乗務後の点呼を記録できます"
            android:textSize="12sp"
            android:textColor="@color/colorBannerHintText"
            android:gravity="center" />

    </LinearLayout>

    <!-- 全日付リスト -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTenko"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="6dp"
        android:clipToPadding="false" />

</LinearLayout>
