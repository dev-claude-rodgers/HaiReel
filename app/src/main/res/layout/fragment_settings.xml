<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/settingsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ヘッダー -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:backgroundTint="?attr/colorSurfaceVariant"
            android:background="?attr/colorSurfaceVariant"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="設定"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- アプリ設定 -->
        <LinearLayout
            android:id="@+id/rowAppSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="⚙️"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="アプリ設定"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="事業者名・車番・ダークモードなど"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- APIキー設定 -->
        <LinearLayout
            android:id="@+id/rowApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="🗺️"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Google APIキー設定"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvApiKeyStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="未設定（ビルド埋め込みキーを使用中）"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- ライセンス -->
        <LinearLayout
            android:id="@+id/rowLicense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="🪪"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ライセンス"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvLicenseStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="試用期間中"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- バックアップ作成 -->
        <LinearLayout
            android:id="@+id/rowBackupCreate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="💾"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="バックアップを作成"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="全データをファイルに保存・共有する"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- バックアップ復元 -->
        <LinearLayout
            android:id="@+id/rowBackupRestore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="📂"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="バックアップから復元"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="バックアップファイルを選択して復元する"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- 使い方・ヘルプ -->
        <LinearLayout
            android:id="@+id/rowHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="❓"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="使い方・ヘルプ"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="基本操作・よくある質問"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- お問い合わせ -->
        <LinearLayout
            android:id="@+id/rowContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="✉️"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="お問い合わせ"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ご質問・不具合のご報告"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- アプリについて -->
        <LinearLayout
            android:id="@+id/rowAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="ℹ️"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="アプリについて"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="バージョン情報・開発者"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- 利用規約 -->
        <LinearLayout
            android:id="@+id/rowTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="📋"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="利用規約"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ご利用に際してのルール・免責事項"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- プライバシーポリシー -->
        <LinearLayout
            android:id="@+id/rowPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="📜"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="プライバシーポリシー"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="個人情報の取り扱いについて"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- 特定商取引法に基づく表記 -->
        <LinearLayout
            android:id="@+id/rowSct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="🏪"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="特定商取引法に基づく表記"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="販売者情報・返金ポリシー"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- データを初期化 -->
        <LinearLayout
            android:id="@+id/rowResetData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="🗑️"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="データをすべて初期化"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorActionRed" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="日報・配達先・ルート・帳票パターン・署名をすべて削除する"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="84dp" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- アプリを終了 -->
        <LinearLayout
            android:id="@+id/rowExit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/selectableItemBackground"
            android:padding="20dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:text="🚪"
                android:textSize="28sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="アプリを終了"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorActionRed" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="アプリを完全に終了する"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
