<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- ヘッダー -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingVertical="6dp"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- フィルタートグル -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipIncomplete"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="すべて"
            android:contentDescription="フィルター切り替え"
            android:textColor="@color/chip_text_selector"
            android:textSize="16sp"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipMinHeight="52dp"
            app:checkedIconVisible="false" />

        <!-- 選択モード解除チップ（選択モード中のみ表示・chipIncompleteと同スタイル） -->
        <com.google.android.material.chip.Chip
            android:id="@+id/buttonSelect"
            style="@style/Widget.MaterialComponents.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="✕ 解除"
            android:contentDescription="選択モードを解除"
            android:textColor="@color/chip_text_selector"
            android:textSize="16sp"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/chip_bg_selector"
            app:chipStrokeColor="@color/chip_stroke_selector"
            app:chipStrokeWidth="1.5dp"
            app:chipMinHeight="52dp"
            app:checkedIconVisible="false"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 地図トグルボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMapToggle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/btn_map_toggle"
            android:contentDescription="地図/リスト切替"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:strokeColor="#FFFFFF"
            app:cornerRadius="8dp" />

        <!-- メニューボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonListMenu"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="52dp"
            android:layout_height="56dp"
            android:text="≡"
            android:contentDescription="メニューを開く"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- 進捗バー -->
    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressDelivery"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#444444" />

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#AAAAAA" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="96dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutProgress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 選択モードのボトムバー -->
    <LinearLayout
        android:id="@+id/layoutSelectionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#111111"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSelectAll"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:singleLine="true"
            app:strokeColor="#FFFFFF"
            android:text="@string/btn_select_all"
            android:contentDescription="全件選択" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSetTimeSlot"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:singleLine="true"
            app:strokeColor="#FFFFFF"
            android:text="🕐 時間帯"
            android:contentDescription="時間帯を設定"
            android:enabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeleteSelected"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:singleLine="true"
            android:text="削除"
            android:contentDescription="選択した配達先を削除"
            android:enabled="false"
            app:backgroundTint="@color/colorError" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 荷室レイアウト表示エリア -->
    <FrameLayout
        android:id="@+id/vanContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="≡ メニュー → 名前・住所を追加\nからルートに追加できます"
        android:textSize="16sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutProgress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
