<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- メニューボタン（左上） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buttonMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:contentDescription="メニュー"
        app:srcCompat="@drawable/ic_menu"
        app:backgroundTint="#1565C0"
        app:tint="#FFFFFF"
        app:fabSize="mini"
        app:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ズームインボタン（右・ズームアウトの上） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buttonZoomIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="拡大"
        app:srcCompat="@drawable/ic_zoom_in"
        app:backgroundTint="#1565C0"
        app:tint="#FFFFFF"
        app:fabSize="mini"
        app:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonZoomOut" />

    <!-- ズームアウトボタン（右・現在地の上） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buttonZoomOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="縮小"
        app:srcCompat="@drawable/ic_zoom_out"
        app:backgroundTint="#1565C0"
        app:tint="#FFFFFF"
        app:fabSize="mini"
        app:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonMyLocation" />

    <!-- 現在地ボタン（右下） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/buttonMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="36dp"
        android:contentDescription="現在地"
        app:srcCompat="@drawable/ic_my_location"
        app:backgroundTint="#1565C0"
        app:tint="#FFFFFF"
        app:fabSize="mini"
        app:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 配達先なし時のEmptyView -->
    <TextView
        android:id="@+id/emptyMapView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍 配達先がありません\nメニュー → 住所をインポートから追加できます"
        android:textSize="15sp"
        android:textColor="#CC000000"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="#DDFFFFFF"
        android:elevation="2dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
