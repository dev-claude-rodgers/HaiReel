<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Androidの自動バックアップからDBとSharedPrefsを除外 -->
    <!-- アプリ内の「バックアップを作成」機能でデータ管理を行う -->
    <exclude domain="database" path="report_db" />
    <exclude domain="database" path="report_db-shm" />
    <exclude domain="database" path="report_db-wal" />
    <exclude domain="sharedpref" path="kado_settings.xml" />
    <exclude domain="sharedpref" path="delivery_prefs.xml" />
    <exclude domain="sharedpref" path="kado_secure.xml" />
    <exclude domain="sharedpref" path="report_patterns.xml" />
</full-backup-content>
